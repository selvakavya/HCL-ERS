#include <iostream>
using namespace std;

struct Date {
    int day, month, year;
};

bool isValid(Date d) {
    if (d.year < 1) return false;
    if (d.month < 1 || d.month > 12) return false;
    if (d.day < 1 || d.day > 31) return false;
    return true;
}

Date createDate(int d, int m, int y) {
    Date temp = {d, m, y};

    if (!isValid(temp)) {
        cout << "Invalid date! Setting default.\n";
        return {1, 1, 2000};
    }
    return temp;
}

int main() {
    Date d = createDate(32, 5, 2024);

    cout << "Date: " << d.day << "/" << d.month << "/" << d.year << endl;

    return 0;
}